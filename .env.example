# Cloud Ops Console - environment configuration
# Copy this file to .env.local and fill in real credentials when wiring real cloud providers.

# Data source: "mock" (default) | "live"
# When set to "live" the app expects credentials below to be present.
DATA_SOURCE=mock

# ----- AWS (Cost Explorer / Deployments via CodePipeline / CloudWatch alarms) -----
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ----- Azure (Cost Management / Pipelines / Monitor) -----
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# ----- GCP (Cloud Billing / Cloud Build / Cloud Monitoring) -----
GCP_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# ----- Optional integrations -----
PAGERDUTY_API_TOKEN=
OPSGENIE_API_KEY=
